{
  "name": "dewey",
  "version": "1.0.9",
  "private": true,
  "description": "Dewey WordPress plugin admin UI and release tooling.",
  "scripts": {
    "start": "wp-scripts start",
    "build": "wp-scripts build",
    "lint:js": "wp-scripts lint-js src",
    "lint:css": "wp-scripts lint-style \"src/**/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "test:js": "wp-scripts test-unit-js",
    "test:php": "php ./tests/php/dewey-core-tests.php",
    "check:docs": "node ./scripts/check-docs-consistency.js",
    "check:security": "node ./scripts/check-security-basics.js",
    "check": "npm run check:docs && npm run check:security",
    "release": "node ./scripts/release-plugin.js",
    "release:dry-run": "node ./scripts/release-plugin.js --dry-run"
  },
  "dependencies": {
    "@wordpress/components": "^32.2.0",
    "@wordpress/element": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@wordpress/scripts": "^31.5.0"
  }
}
